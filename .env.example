# Neon PostgreSQL Database URL
DATABASE_URL=

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Maps API Key for MapExplorer
VITE_GOOGLE_MAPS_API_KEY=

# App URL — used as base for Daraja callback and OAuth redirects
APP_URL="https://your-app-url.example.com"
JWKS_URL=

# ── M-Pesa Daraja API ──────────────────────────────────────────────────────────
# Register at https://developer.safaricom.co.ke → Create App → get credentials
# Set MPESA_ENV=sandbox for testing, production for live
MPESA_ENV=sandbox

# Consumer Key and Secret from your Daraja app
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Lipa Na M-Pesa shortcode (paybill/till number)
# Sandbox test shortcode: 174379
MPESA_SHORTCODE=174379

# Lipa Na M-Pesa Online Passkey
# Sandbox passkey: bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Public URL where Safaricom will POST payment confirmations
# Must be HTTPS and publicly reachable (use ngrok in dev)
# Will be appended with /api/mpesa/callback automatically
MPESA_CALLBACK_URL=https://your-app-url.example.com

# ── MiniPay / Celo (Asante Drop donations) ────────────────────────────────
# Celo wallet address that receives all community donations
# Get a free Celo wallet at app.minipay.opera.com or Valora app
VITE_COMMUNITY_WALLET=0xYourCeloWalletAddress

# 'testnet' uses Alfajores (safe for dev/testing), blank or 'mainnet' for production
VITE_CELO_ENV=testnet
